# Turso (libSQL) — https://turso.tech
TURSO_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token

# Resend — https://resend.com
RESEND_API_KEY=re_your_resend_key

# Sender address (must be a verified domain in Resend)
FROM_EMAIL=Cumpleaños <cumpleanos@yourdomain.com>

# Cron protection — any random string, set the same in Vercel env vars
CRON_SECRET=a_random_secret_string