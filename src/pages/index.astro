---
import { getUpcomingBirthdays } from "@/lib/actions"
import { tryCatch } from "@/lib/try-catch"

import BaseLayout from "@/layouts/base.astro"
import RegisterForm from "@/components/RegisterForm"
import UpcomingList from "@/components/UpcomingList"

const result = await tryCatch(getUpcomingBirthdays())
const upcoming = result.error ? [] : result.data
---

<BaseLayout>
  <div class="w-full max-w-md space-y-10">
    <!-- Header -->
    <header class="text-center space-y-2">
      <p class="text-4xl">🎂</p>
      <h1 class="text-4xl font-bold text-warm-dark leading-tight">Círculo de cumpleaños</h1>
      <p class="text-warm-muted text-sm max-w-xs mx-auto">
        Registrate y recibe recordatorios cada vez que alguien del grupo cumpla años.
      </p>
    </header>

    <!-- Form card -->
    <section class="card">
      <h2 class="text-xl font-bold text-warm-dark mb-5">Unirme al círculo</h2>
      <RegisterForm client:load />
    </section>

    <!-- Upcoming -->
    <section class="space-y-3">
      <h2 class="text-xl font-bold text-warm-dark">Próximos 30 días</h2>
      <UpcomingList upcoming={upcoming} client:load />
    </section>
  </div>
</BaseLayout>
